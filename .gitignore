# ── Secrets / credentials (NEVER commit) ──
.env
.env.*
*.pem
*.key
.netrc

# ── Model weights & checkpoints ──
*.safetensors
*.pt
*.pth
*.bin
*.ckpt
*.gguf
checkpoints/
checkpoint-*/
adapters/
lora/
*.lora

# ── Experiment tracking / logs ──
wandb/
runs/
tensorboard/
*.log
logs/

# ── Generated eval outputs (regenerated by run_mvp) ──
results/
*.eval

# ── Datasets / large artifacts ──
# NOTE: anchored to repo root (leading /) so they DON'T catch the source
# subpackage newcomb_eval/data/ (which holds small JSON datasets + code).
*.parquet
*.arrow
*.npy
*.npz
/data/
/datasets/
# external Oesterheld Newcomb-like dataset (own LICENSE — do not commit; see
# newcomb_eval/newcomblike_oesterheld.py docstring for the one-line download)
newcomb_eval/data/oesterheld/
*.zip

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# ── OS / editor cruft ──
.DS_Store
*.swp
.vscode/
.idea/

# generated mechanism-credibility dataset variants (regenerate: python -m newcomb_eval.gen_mechanism_dataset)
newcomb_eval/data/dataset_mech_*.json
