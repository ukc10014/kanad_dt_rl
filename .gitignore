# ── Secrets / credentials (NEVER commit) ──
.env
.env.*
*.pem
*.key
.netrc

# ── Model weights & checkpoints ──
*.safetensors
*.pt
*.pth
*.bin
*.ckpt
*.gguf
checkpoints/
checkpoint-*/
adapters/
lora/
*.lora

# ── Experiment tracking / logs ──
wandb/
runs/
tensorboard/
*.log
logs/
# EXCEPTION: recovered/parsed RL training dynamics are tracked under results/logs/
# (tiny per-step CSVs + their raw source step-logs). This narrow re-include keeps the
# blanket *.log / logs/ rules above from silently swallowing the dynamics again — the
# bug that forced a prior session to rebuild the curves from ~4 transcribed checkpoints.
# Stray *.log elsewhere (and heavy logs/ dirs) stay ignored.
!results/logs/
!results/logs/**

# ── Generated eval outputs ──
# results/ IS tracked so CoT logs / transcripts / summaries / plots upload to GitHub
# (~16 MB). Only the heavy bits are excluded: LoRA adapters (~7 GB) and Inspect .eval
# logs. (Stray weights are also caught by the *.safetensors/*.bin/... rules above.)
results/adapters/
*.eval

# ── Datasets / large artifacts ──
# NOTE: anchored to repo root (leading /) so they DON'T catch the source
# subpackage newcomb_eval/data/ (which holds small JSON datasets + code).
*.parquet
*.arrow
*.npy
*.npz
/data/
/datasets/
# external Oesterheld Newcomb-like dataset (own LICENSE — do not commit; see
# newcomb_eval/newcomblike_oesterheld.py docstring for the one-line download)
newcomb_eval/data/oesterheld/
*.zip

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# ── OS / editor cruft ──
.DS_Store
*.swp
.vscode/
.idea/

# generated mechanism-credibility dataset variants (regenerate: python -m newcomb_eval.gen_mechanism_dataset)
newcomb_eval/data/dataset_mech_*.json
